<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= settings?.site_title || 'Bellona Luxury Hotel' %> - Home</title>
  <%- include('partials/links') %>
  <style>
    .availability-form {
      margin-top: -50px;
      position: relative;
      z-index: 2;
    }
    @media screen and (max-width: 575px) {
      .availability-form {
        margin-top: 20px;
      }
    }
  </style>
</head>
<body class="bg-light">

  <%- include('partials/header') %>

  <!-- Carousel Slider -->
  <div class="container-fluid px-lg-4 mt-4">
    <div class="swiper swiper-container">
      <div class="swiper-wrapper">
        <% if (locals.carousel && carousel.length > 0) { %>
          <% carousel.forEach(img => { %>
            <div class="swiper-slide">
              <img src="/uploads/carousel/<%= img %>" class="w-100 d-block" style="height: 450px; object-fit: cover;" />
            </div>
          <% }) %>
        <% } else { %>
          <!-- Fallback default slider images -->
          <div class="swiper-slide"><img src="/images/carousel/1.png" class="w-100 d-block" style="height: 450px; object-fit: cover;" /></div>
          <div class="swiper-slide"><img src="/images/carousel/2.png" class="w-100 d-block" style="height: 450px; object-fit: cover;" /></div>
          <div class="swiper-slide"><img src="/images/carousel/3.png" class="w-100 d-block" style="height: 450px; object-fit: cover;" /></div>
          <div class="swiper-slide"><img src="/images/carousel/4.png" class="w-100 d-block" style="height: 450px; object-fit: cover;" /></div>
        <% } %>
      </div>
    </div>
  </div>

  <!-- Check Availability Form -->
  <div class="container availability-form">
    <div class="row">
      <div class="col-lg-12 bg-white shadow p-4 rounded">
        <h5 class="mb-4 fw-bold">Check Booking Availability</h5>
        <form action="/rooms" method="GET">
          <div class="row align-items-end">
            <div class="col-lg-3 mb-3">
              <label class="form-label font-weight-500">Check-In</label>
              <input type="date" name="checkin" required class="form-control shadow-none">
            </div>
            <div class="col-lg-3 mb-3">
              <label class="form-label font-weight-500">Check-Out</label>
              <input type="date" name="checkout" required class="form-control shadow-none">
            </div>
            <div class="col-lg-3 mb-3">
              <label class="form-label font-weight-500">Adults</label>
              <select name="adult" class="form-select shadow-none">
                <option value="1">One</option>
                <option value="2" selected>Two</option>
                <option value="3">Three</option>
                <option value="4">Four</option>
              </select>
            </div>
            <div class="col-lg-2 mb-3">
              <label class="form-label font-weight-500">Children</label>
              <select name="children" class="form-select shadow-none">
                <option value="0" selected>None</option>
                <option value="1">One</option>
                <option value="2">Two</option>
                <option value="3">Three</option>
              </select>
            </div>
            <div class="col-lg-1 mb-3">
              <button type="submit" class="btn text-white shadow-none custom-bg w-100 py-2 border-0">Submit</button>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>

  <!-- Our Rooms -->
  <h2 class="mt-5 pt-4 mb-4 text-center fw-bold h-font">OUR ROOMS</h2>
  <div class="container">
    <div class="row justify-content-center">
      <% if (rooms && rooms.length > 0) { %>
        <% rooms.forEach(room => { %>
          <div class="col-lg-4 col-md-6 my-3">
            <div class="card border-0 shadow" style="max-width: 350px; margin: auto;">
              <img src="/uploads/rooms/<%= room.thumbImage || 'room1.jpeg' %>" class="card-img-top" style="height: 220px; object-fit: cover;">
              <div class="card-body">
                <h5 class="fw-bold"><%= room.name %></h5>
                <h6 class="mb-4 text-success font-weight-500">₹<%= room.price.toLocaleString() %>/night</h6>
                
                <div class="features mb-4">
                  <h6 class="mb-1 fw-bold" style="font-size: 14px;">Features</h6>
                  <% room.features.forEach(feat => { %>
                    <span class="badge text-bg-light text-dark text-wrap lh-base m-1"><%= feat.name %></span>
                  <% }) %>
                </div>

                <div class="facilities mb-4">
                  <h6 class="mb-1 fw-bold" style="font-size: 14px;">Facilities</h6>
                  <% room.facilities.forEach(fac => { %>
                    <span class="badge text-bg-light text-dark text-wrap lh-base m-1"><%= fac.name %></span>
                  <% }) %>
                </div>

                <div class="guests mb-4">
                  <h6 class="mb-1 fw-bold" style="font-size: 14px;">Guests Capacity</h6>
                  <span class="badge text-bg-light text-dark text-wrap lh-base"><%= room.adult %> Adults</span>
                  <span class="badge text-bg-light text-dark text-wrap lh-base"><%= room.children %> Children</span>
                </div>

                <div class="rating mb-4">
                  <h6 class="mb-1 fw-bold" style="font-size: 14px;">Rating</h6>
                  <span class="badge rounded-pill bg-light">
                    <i class="bi bi-star-fill text-warning"></i>
                    <i class="bi bi-star-fill text-warning"></i>
                    <i class="bi bi-star-fill text-warning"></i>
                    <i class="bi bi-star-fill text-warning"></i>
                    <i class="bi bi-star-fill text-warning"></i>
                  </span>
                </div>

                <div class="d-flex justify-content-evenly mb-2">
                  <a href="/confirm-booking/<%= room._id %>" class="btn btn-sm text-white custom-bg shadow-none border-0 px-3">Book Now</a>
                  <a href="/rooms" class="btn btn-sm btn-outline-dark shadow-none px-3">More Details</a>
                </div>
              </div>
            </div>
          </div>
        <% }) %>
      <% } else { %>
        <p class="text-center">No rooms registered yet.</p>
      <% } %>
    </div>
    <div class="col-lg-12 text-center mt-4">
      <a href="/rooms" class="btn btn-outline-dark rounded-0 fw-bold shadow-none">More Rooms -></a>
    </div>
  </div>

  <!-- Dynamic Facilities Section -->
  <h2 class="mt-5 pt-4 mb-4 text-center fw-bold h-font">OUR FACILITIES</h2>
  <div class="container">
    <div class="row justify-content-evenly px-lg-0 px-md-0 px-5">
      <% if (facilities && facilities.length > 0) { %>
        <% facilities.slice(0, 6).forEach(fac => { %>
          <div class="col-lg-2 col-md-3 text-center bg-white rounded shadow py-4 my-3 mx-2 pop">
            <img src="/uploads/facilities/<%= fac.icon %>" width="80px" height="80px" style="object-fit: contain;">
            <h5 class="mt-3 fw-bold"><%= fac.name %></h5>
          </div>
        <% }) %>
      <% } else { %>
        <p class="text-center">No facilities registered yet.</p>
      <% } %>
      <div class="col-lg-12 text-center mt-4">
        <a href="/facilities" class="btn btn-outline-dark rounded-0 fw-bold shadow-none">More Facilities -></a>
      </div>
    </div>
  </div>

  <!-- Testimonials -->
  <h2 class="mt-5 pt-4 mb-4 text-center fw-bold h-font">TESTIMONIALS</h2>
  <div class="container mt-5">
    <div class="swiper mySwiper">
      <div class="swiper-wrapper mb-5">
        <div class="swiper-slide bg-white p-4 rounded shadow-sm">
          <div class="profile d-flex align-items-center mb-2">
            <img src="/images/customers.svg" width="30px">
            <h6 class="m-0 ms-2 fw-bold">Rahul Sharma</h6>
          </div>
          <p class="text-secondary">Excellent stay! The service was outstanding, the staff was extremely friendly, and the deluxe room was clean and luxurious. Highly recommended!</p>
          <div class="rating">
            <i class="bi bi-star-fill text-warning"></i>
            <i class="bi bi-star-fill text-warning"></i>
            <i class="bi bi-star-fill text-warning"></i>
            <i class="bi bi-star-fill text-warning"></i>
            <i class="bi bi-star-fill text-warning"></i>
          </div>
        </div>
        <div class="swiper-slide bg-white p-4 rounded shadow-sm">
          <div class="profile d-flex align-items-center mb-2">
            <img src="/images/customers.svg" width="30px">
            <h6 class="m-0 ms-2 fw-bold">Ananya Singh</h6>
          </div>
          <p class="text-secondary">Bellona Hotel provides the best spa and room services. The food was delicious, and the check-in and checkout processes were super fast. A 5-star experience!</p>
          <div class="rating">
            <i class="bi bi-star-fill text-warning"></i>
            <i class="bi bi-star-fill text-warning"></i>
            <i class="bi bi-star-fill text-warning"></i>
            <i class="bi bi-star-fill text-warning"></i>
            <i class="bi bi-star-fill text-warning"></i>
          </div>
        </div>
        <div class="swiper-slide bg-white p-4 rounded shadow-sm">
          <div class="profile d-flex align-items-center mb-2">
            <img src="/images/customers.svg" width="30px">
            <h6 class="m-0 ms-2 fw-bold">Vikram Aditya</h6>
          </div>
          <p class="text-secondary">A magnificent structure and world-class swimming pool facilities. The presidential suite represents pure royalty. I will definitely visit again with my family.</p>
          <div class="rating">
            <i class="bi bi-star-fill text-warning"></i>
            <i class="bi bi-star-fill text-warning"></i>
            <i class="bi bi-star-fill text-warning"></i>
            <i class="bi bi-star-fill text-warning"></i>
            <i class="bi bi-star-fill text-warning"></i>
          </div>
        </div>
      </div>
      <div class="swiper-pagination"></div>
    </div>
  </div>

  <!-- Reach Us Section -->
  <h2 class="mt-5 pt-4 mb-4 text-center fw-bold h-font">REACH US</h2>
  <div class="container mb-5">
    <div class="row">
      <div class="col-lg-8 col-md-8 p-4 mb-lg-0 mb-3 bg-white rounded shadow-sm">
        <iframe class="w-100 rounded" height="320px" src="<%= contact?.iframe %>" loading="lazy" style="border: 0;"></iframe>
      </div>
      <div class="col-lg-4 col-md-4 d-flex flex-column justify-content-between">
        <div class="bg-white p-4 rounded shadow-sm mb-4">
          <h5 class="fw-bold mb-3">Call Us</h5>
          <a href="tel:<%= contact?.pn1 %>" class="d-inline-block mb-2 text-decoration-none text-dark">
            <i class="bi bi-telephone-outbound-fill text-primary"></i> <%= contact?.pn1 %>
          </a><br>
          <% if (contact?.pn2) { %>
            <a href="tel:<%= contact?.pn2 %>" class="d-inline-block text-decoration-none text-dark">
              <i class="bi bi-telephone-outbound-fill text-primary"></i> <%= contact?.pn2 %>
            </a>
          <% } %>
        </div>
        <div class="bg-white p-4 rounded shadow-sm">
          <h5 class="fw-bold mb-3">Follow Us</h5>
          <a href="<%= contact?.tw %>" target="_blank" class="d-inline-block mb-3 me-2">
            <span class="badge bg-light text-dark fs-6 p-2 border">
              <i class="bi bi-twitter text-primary"></i> Twitter
            </span>
          </a>
          <a href="<%= contact?.fb %>" target="_blank" class="d-inline-block mb-3 me-2">
            <span class="badge bg-light text-dark fs-6 p-2 border">
              <i class="bi bi-facebook text-primary"></i> Facebook
            </span>
          </a>
          <a href="<%= contact?.insta %>" target="_blank" class="d-inline-block">
            <span class="badge bg-light text-dark fs-6 p-2 border">
              <i class="bi bi-instagram text-danger"></i> Instagram
            </span>
          </a>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>

  <!-- Carousel Design using swiper js -->
  <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
  <!-- Initialize Swiper -->
  <script>
    var swiper1 = new Swiper(".swiper-container", {
      spaceBetween: 30,
      effect: "fade",
      loop: true,
      autoplay: {
        delay: 3500,
        disableOnInteraction: false,
      }
    });

    var swiper2 = new Swiper(".mySwiper", {
      effect: "coverflow",
      grabCursor: true,
      centeredSlides: true,
      slidesPerView: "auto",
      loop: true,
      coverflowEffect: {
        rotate: 40,
        stretch: 0,
        depth: 100,
        modifier: 1,
        slideShadows: true,
      },
      pagination: {
        el: ".swiper-pagination",
      },
      breakpoints: {
        320: { slidesPerView: 1 },
        640: { slidesPerView: 1 },
        768: { slidesPerView: 2 },
        1024: { slidesPerView: 3 },
      }
    });
  </script>
</body>
</html>
