<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel - User Queries</title>
    <%- include('../partials/links') %>
</head>
<body class="bg-light">

    <div class="container-fluid" id="main-container">
        <div class="row">
            <!-- Sidebar -->
            <%- include('../partials/admin_header') %>

            <!-- Main Content -->
            <div class="col-lg-10 ms-auto p-4" id="main-content">
                <h3 class="fw-bold h-font mb-4 border-bottom pb-2">USER QUERIES</h3>

                <div class="card border-0 shadow-sm rounded-3 bg-white">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <h5 class="card-title m-0 fw-bold">Customer Messages</h5>
                            <button onclick="deleteAllQueries()" class="btn btn-danger btn-sm shadow-none"><i class="bi bi-trash-fill"></i> Delete All</button>
                        </div>
                        <div class="table-responsive">
                            <table class="table table-hover align-middle border text-center">
                                <thead>
                                    <tr class="table-dark">
                                        <th>#</th>
                                        <th>Name</th>
                                        <th>Email</th>
                                        <th>Subject</th>
                                        <th style="width: 30%;">Message</th>
                                        <th>Date</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody id="queries-table-body">
                                    <!-- Loaded dynamically -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script>
        function showAlert(type, msg) {
            const bsClass = (type === 'success') ? 'alert-success' : 'alert-danger';
            const element = document.createElement('div');
            element.innerHTML = `
                <div class="alert ${bsClass} alert-dismissible fade show custom-alert shadow" role="alert" style="position: fixed; top: 25px; right: 25px; z-index: 1060; min-width: 250px;">
                    <span class="me-3">${msg}</span>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            `;
            document.body.append(element);
            setTimeout(() => element.remove(), 3000);
        }

        document.getElementById('menu-queries').classList.add('active');

        // Load contact messages
        async function getQueries() {
            try {
                const response = await fetch('/admin/queries/list');
                const queries = await response.json();
                const tbody = document.getElementById('queries-table-body');
                tbody.innerHTML = '';

                if (queries.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="7" class="text-center text-secondary py-3">No contact messages received.</td></tr>`;
                    return;
                }

                queries.forEach((q, idx) => {
                    const markReadBtn = !q.seen 
                        ? `<button onclick="markAsSeen('${q._id}')" class="btn btn-sm btn-primary shadow-none me-1">Mark Read</button>` 
                        : `<span class="badge bg-light text-success border border-success me-1 px-2 py-1"><i class="bi bi-check2-all"></i> Read</span>`;

                    tbody.innerHTML += `
                        <tr class="${q.seen ? '' : 'table-warning fw-bold'}">
                            <td>${idx + 1}</td>
                            <td>${q.name}</td>
                            <td>${q.email}</td>
                            <td>${q.subject}</td>
                            <td class="text-start" style="font-size: 13px;">${q.message}</td>
                            <td style="font-size: 12px;">${new Date(q.createdAt).toLocaleString()}</td>
                            <td>
                                <div class="d-flex align-items-center justify-content-center">
                                    ${markReadBtn}
                                    <button onclick="deleteQuery('${q._id}')" class="btn btn-danger btn-sm shadow-none"><i class="bi bi-trash"></i></button>
                                </div>
                            </td>
                        </tr>
                    `;
                });
            } catch (err) {
                showAlert('danger', 'Error loading user queries.');
            }
        }

        // Mark Seen
        async function markAsSeen(id) {
            try {
                const response = await fetch(`/admin/queries/seen/${id}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                if (response.ok) {
                    showAlert('success', 'Message marked as read.');
                    getQueries();
                } else {
                    showAlert('danger', 'Failed to update query status.');
                }
            } catch (err) {
                showAlert('danger', 'Error processing query read state.');
            }
        }

        // Delete Query
        async function deleteQuery(id) {
            if (!confirm('Are you sure you want to delete this message?')) return;
            try {
                const response = await fetch(`/admin/queries/delete/${id}`, { method: 'DELETE' });
                if (response.ok) {
                    showAlert('success', 'Message deleted.');
                    getQueries();
                } else {
                    showAlert('danger', 'Failed to delete message.');
                }
            } catch (err) {
                showAlert('danger', 'Error deleting message.');
            }
        }

        // Delete All Queries
        async function deleteAllQueries() {
            if (!confirm('Are you sure you want to delete ALL messages? This cannot be undone.')) return;
            try {
                const response = await fetch('/admin/queries/delete-all', { method: 'DELETE' });
                if (response.ok) {
                    showAlert('success', 'All messages cleared.');
                    getQueries();
                } else {
                    showAlert('danger', 'Failed to clear messages.');
                }
            } catch (err) {
                showAlert('danger', 'Error clearing messages.');
            }
        }

        // Initial Load
        getQueries();
    </script>
</body>
</html>
