<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel - New Bookings</title>
    <%- include('../partials/links') %>
</head>
<body class="bg-light">

    <div class="container-fluid" id="main-container">
        <div class="row">
            <!-- Sidebar -->
            <%- include('../partials/admin_header') %>

            <!-- Main Content -->
            <div class="col-lg-10 ms-auto p-4" id="main-content">
                <h3 class="fw-bold h-font mb-4 border-bottom pb-2">NEW BOOKINGS</h3>

                <div class="card border-0 shadow-sm rounded-3 bg-white">
                    <div class="card-body">
                        <h5 class="card-title fw-bold mb-3">Reservations Pending Check-In</h5>
                        
                        <div class="table-responsive">
                            <table class="table table-hover align-middle border text-center" style="min-width: 1000px;">
                                <thead>
                                    <tr class="table-dark">
                                        <th>#</th>
                                        <th>Guest Details</th>
                                        <th>Room Details</th>
                                        <th>Booking Details</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody id="new-bookings-table-body">
                                    <!-- Loaded dynamically -->
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Assign Room & Check-In Modal -->
    <div class="modal fade" id="assign-room-modal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form id="assign-room-form">
                    <input type="hidden" name="booking_id" id="assign-booking-id">
                    <div class="modal-header">
                        <h5 class="modal-title fw-bold">Assign Room & Check-In</h5>
                        <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Assign Room Number</label>
                            <input type="text" name="room_number" placeholder="e.g. Room 104, Deluxe 205" required class="form-control shadow-none">
                            <small class="text-secondary">Please allocate a physically vacant room matching the booked type.</small>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary shadow-none" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-success shadow-none border-0 text-white">Confirm Arrival</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        function showAlert(type, msg) {
            const bsClass = (type === 'success') ? 'alert-success' : 'alert-danger';
            const element = document.createElement('div');
            element.innerHTML = `
                <div class="alert ${bsClass} alert-dismissible fade show custom-alert shadow" role="alert" style="position: fixed; top: 25px; right: 25px; z-index: 1060; min-width: 250px;">
                    <span class="me-3">${msg}</span>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            `;
            document.body.append(element);
            setTimeout(() => element.remove(), 3000);
        }

        // Keep dropdown open
        document.getElementById('bookingDropdown').classList.add('show');
        document.getElementById('menu-new-bookings').classList.add('active');

        // Fetch bookings
        async function getNewBookings() {
            try {
                const response = await fetch('/admin/bookings/new/list');
                const bookings = await response.json();
                const tbody = document.getElementById('new-bookings-table-body');
                tbody.innerHTML = '';

                if (bookings.length === 0) {
                    tbody.innerHTML = `<tr><td colspan="5" class="text-center text-secondary py-4">No new bookings found.</td></tr>`;
                    return;
                }

                bookings.forEach((b, idx) => {
                    tbody.innerHTML += `
                        <tr>
                            <td>${idx + 1}</td>
                            <td class="text-start">
                                <span class="fw-bold">Name:</span> ${b.user_name}<br>
                                <span class="fw-bold">Phone:</span> ${b.user_phone}<br>
                                <span class="fw-bold">Address:</span> ${b.user_address}
                            </td>
                            <td class="text-start">
                                <span class="fw-bold">Room:</span> ${b.room.name}<br>
                                <span class="fw-bold">Price:</span> ₹${b.room.price}/night<br>
                                <span class="fw-bold">Check-in:</span> ${new Date(b.check_in).toDateString()}<br>
                                <span class="fw-bold">Check-out:</span> ${new Date(b.check_out).toDateString()}
                            </td>
                            <td class="text-start">
                                <span class="fw-bold">Booking ID:</span> ${b.booking_id}<br>
                                <span class="fw-bold">Trans ID:</span> ${b.trans_id}<br>
                                <span class="fw-bold">Paid Amount:</span> <span class="text-success fw-bold">₹${b.amount.toLocaleString()}</span><br>
                                <span class="fw-bold">Date:</span> ${new Date(b.createdAt).toLocaleString()}
                            </td>
                            <td>
                                <div class="d-flex flex-column gap-2 px-2">
                                    <button onclick="openCheckInModal('${b._id}')" class="btn btn-success btn-sm text-white shadow-none border-0 py-2"><i class="bi bi-check2-circle"></i> Check-In</button>
                                    <button onclick="cancelBooking('${b._id}')" class="btn btn-outline-danger btn-sm shadow-none py-2"><i class="bi bi-x-circle"></i> Cancel</button>
                                </div>
                            </td>
                        </tr>
                    `;
                });
            } catch (err) {
                showAlert('danger', 'Error loading new bookings list.');
            }
        }

        // Open Check-in Modal
        function openCheckInModal(id) {
            document.getElementById('assign-booking-id').value = id;
            bootstrap.Modal.getOrCreateInstance(document.getElementById('assign-room-modal')).show();
        }

        // Submit Check-in Form
        const assignForm = document.getElementById('assign-room-form');
        assignForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const id = document.getElementById('assign-booking-id').value;
            const room_number = assignForm.elements.room_number.value;

            try {
                const response = await fetch(`/admin/bookings/check-in/${id}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ room_number })
                });
                if (response.ok) {
                    showAlert('success', 'Guest checked in successfully!');
                    assignForm.reset();
                    bootstrap.Modal.getInstance(document.getElementById('assign-room-modal')).hide();
                    getNewBookings();
                } else {
                    showAlert('danger', 'Failed to check-in guest.');
                }
            } catch (err) {
                showAlert('danger', 'Error processing check-in.');
            }
        });

        // Cancel Booking
        async function cancelBooking(id) {
            if (!confirm('Are you sure you want to cancel this booking?')) return;
            try {
                const response = await fetch(`/admin/bookings/cancel/${id}`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' }
                });
                if (response.ok) {
                    showAlert('success', 'Booking cancelled. Marked for refund.');
                    getNewBookings();
                } else {
                    showAlert('danger', 'Failed to cancel booking.');
                }
            } catch (err) {
                showAlert('danger', 'Error processing cancellation.');
            }
        }

        // Load initially
        getNewBookings();
    </script>
</body>
</html>
