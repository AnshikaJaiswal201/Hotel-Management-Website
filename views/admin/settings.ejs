<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel - Settings</title>
    <%- include('../partials/links') %>
</head>
<body class="bg-light">

    <div class="container-fluid" id="main-container">
        <div class="row">
            <!-- Sidebar -->
            <%- include('../partials/admin_header') %>

            <!-- Main Content -->
            <div class="col-lg-10 ms-auto p-4" id="main-content">
                <h3 class="fw-bold h-font mb-4 border-bottom pb-2">SETTINGS MANAGEMENT</h3>

                <!-- General Settings Card -->
                <div class="card border-0 shadow-sm rounded-3 mb-4 bg-white">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <h5 class="card-title m-0 fw-bold">General Settings</h5>
                            <button type="button" class="btn btn-dark btn-sm shadow-none" data-bs-toggle="modal" data-bs-target="#general-settings-modal">
                                <i class="bi bi-pencil-square"></i> Edit
                            </button>
                        </div>
                        <h6 class="card-subtitle mb-1 fw-bold text-dark">Website Title</h6>
                        <p class="card-text text-secondary mb-3" id="site-title-val"><%= settings.site_title %></p>
                        
                        <h6 class="card-subtitle mb-1 fw-bold text-dark">About Us Text</h6>
                        <p class="card-text text-secondary mb-3" id="site-about-val"><%= settings.site_about %></p>
                        
                        <!-- Shutdown Web Toggle -->
                        <div class="bg-light p-3 rounded d-flex align-items-center justify-content-between">
                            <div>
                                <h6 class="fw-bold m-0">Shutdown Website</h6>
                                <small class="text-secondary">When turned on, the booking system will be locked and a notice will be displayed to users.</small>
                            </div>
                            <div class="form-check form-switch fs-5">
                                <input class="form-check-input shadow-none" type="checkbox" role="switch" id="shutdown-toggle" onchange="toggleShutdown(this.checked)" <%= settings.shutdown ? 'checked' : '' %>>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Contact Details Card -->
                <div class="card border-0 shadow-sm rounded-3 mb-4 bg-white">
                    <div class="card-body">
                        <div class="d-flex align-items-center justify-content-between mb-3">
                            <h5 class="card-title m-0 fw-bold">Contact Details</h5>
                            <button type="button" class="btn btn-dark btn-sm shadow-none" data-bs-toggle="modal" data-bs-target="#contact-settings-modal">
                                <i class="bi bi-pencil-square"></i> Edit
                            </button>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <h6 class="fw-bold text-dark mb-1">Address</h6>
                                <p class="text-secondary mb-3" id="address-val"><%= contact.address %></p>
                                
                                <h6 class="fw-bold text-dark mb-1">Google Map Link</h6>
                                <p class="text-secondary mb-3 text-truncate" id="gmap-val"><%= contact.gmap %></p>
                                
                                <h6 class="fw-bold text-dark mb-1">Phone Numbers</h6>
                                <p class="text-secondary mb-1">1: <span id="pn1-val"><%= contact.pn1 %></span></p>
                                <p class="text-secondary mb-3">2: <span id="pn2-val"><%= contact.pn2 %></span></p>
                            </div>
                            <div class="col-md-6">
                                <h6 class="fw-bold text-dark mb-1">Email</h6>
                                <p class="text-secondary mb-3" id="email-val"><%= contact.email %></p>
                                
                                <h6 class="fw-bold text-dark mb-1">Social Links</h6>
                                <p class="text-secondary mb-1">FB: <span id="fb-val"><%= contact.fb %></span></p>
                                <p class="text-secondary mb-1">Insta: <span id="insta-val"><%= contact.insta %></span></p>
                                <p class="text-secondary mb-3">Twitter: <span id="tw-val"><%= contact.tw %></span></p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- General Settings Edit Modal -->
    <div class="modal fade" id="general-settings-modal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content">
                <form id="general-settings-form">
                    <div class="modal-header">
                        <h5 class="modal-title fw-bold">Edit General Settings</h5>
                        <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="mb-3">
                            <label class="form-label">Website Title</label>
                            <input type="text" name="site_title" value="<%= settings.site_title %>" required class="form-control shadow-none">
                        </div>
                        <div class="mb-3">
                            <label class="form-label">About Us Text</label>
                            <textarea name="site_about" required class="form-control shadow-none" rows="4"><%= settings.site_about %></textarea>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary shadow-none" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-dark shadow-none border-0">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Contact Settings Edit Modal -->
    <div class="modal fade" id="contact-settings-modal" data-bs-backdrop="static" data-bs-keyboard="false" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content">
                <form id="contact-settings-form">
                    <div class="modal-header">
                        <h5 class="modal-title fw-bold">Edit Contact Settings</h5>
                        <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
                    </div>
                    <div class="modal-body">
                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Address</label>
                                <input type="text" name="address" value="<%= contact.address %>" required class="form-control shadow-none">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Google Map Location Link</label>
                                <input type="text" name="gmap" value="<%= contact.gmap %>" required class="form-control shadow-none">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Phone 1</label>
                                <input type="text" name="pn1" value="<%= contact.pn1 %>" required class="form-control shadow-none">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Phone 2</label>
                                <input type="text" name="pn2" value="<%= contact.pn2 %>" class="form-control shadow-none">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Email</label>
                                <input type="email" name="email" value="<%= contact.email %>" required class="form-control shadow-none">
                            </div>
                            <div class="col-md-6 mb-3">
                                <label class="form-label">Google Maps Embed Iframe URL</label>
                                <input type="text" name="iframe" value="<%= contact.iframe %>" required class="form-control shadow-none">
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Facebook Link</label>
                                <input type="text" name="fb" value="<%= contact.fb %>" class="form-control shadow-none">
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Instagram Link</label>
                                <input type="text" name="insta" value="<%= contact.insta %>" class="form-control shadow-none">
                            </div>
                            <div class="col-md-4 mb-3">
                                <label class="form-label">Twitter Link</label>
                                <input type="text" name="tw" value="<%= contact.tw %>" class="form-control shadow-none">
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary shadow-none" data-bs-dismiss="modal">Cancel</button>
                        <button type="submit" class="btn btn-dark shadow-none border-0">Save Changes</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <!-- Alerts Notification Script -->
    <script>
        function showAlert(type, msg) {
            const bsClass = (type === 'success') ? 'alert-success' : 'alert-danger';
            const element = document.createElement('div');
            element.innerHTML = `
                <div class="alert ${bsClass} alert-dismissible fade show custom-alert shadow" role="alert" style="position: fixed; top: 25px; right: 25px; z-index: 1060; min-width: 250px;">
                    <span class="me-3">${msg}</span>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="alert" aria-label="Close"></button>
                </div>
            `;
            document.body.append(element);
            setTimeout(() => element.remove(), 3000);
        }

        document.getElementById('menu-settings').classList.add('active');

        // Toggle Shutdown mode
        async function toggleShutdown(val) {
            try {
                const response = await fetch('/admin/settings/shutdown', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ shutdown: val })
                });
                if (response.ok) {
                    showAlert('success', val ? 'Website Shutdown activated.' : 'Website Shutdown deactivated.');
                } else {
                    showAlert('danger', 'Failed to toggle shutdown mode.');
                }
            } catch (err) {
                showAlert('danger', 'Error updating shutdown state.');
            }
        }

        // Save General Settings
        const generalForm = document.getElementById('general-settings-form');
        generalForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            const site_title = generalForm.elements.site_title.value;
            const site_about = generalForm.elements.site_about.value;

            try {
                const response = await fetch('/admin/settings/general', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ site_title, site_about })
                });
                if (response.ok) {
                    showAlert('success', 'General settings updated successfully!');
                    document.getElementById('site-title-val').innerText = site_title;
                    document.getElementById('site-about-val').innerText = site_about;
                    bootstrap.Modal.getInstance(document.getElementById('general-settings-modal')).hide();
                } else {
                    showAlert('danger', 'Failed to update general settings.');
                }
            } catch (err) {
                showAlert('danger', 'Error updating general settings.');
            }
        });

        // Save Contact Settings
        const contactForm = document.getElementById('contact-settings-form');
        contactForm.addEventListener('submit', async (e) => {
            e.preventDefault();
            
            const address = contactForm.elements.address.value;
            const gmap = contactForm.elements.gmap.value;
            const pn1 = contactForm.elements.pn1.value;
            const pn2 = contactForm.elements.pn2.value;
            const email = contactForm.elements.email.value;
            const fb = contactForm.elements.fb.value;
            const insta = contactForm.elements.insta.value;
            const tw = contactForm.elements.tw.value;
            const iframe = contactForm.elements.iframe.value;

            try {
                const response = await fetch('/admin/settings/contact', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ address, gmap, pn1, pn2, email, fb, insta, tw, iframe })
                });
                if (response.ok) {
                    showAlert('success', 'Contact details updated successfully!');
                    document.getElementById('address-val').innerText = address;
                    document.getElementById('gmap-val').innerText = gmap;
                    document.getElementById('pn1-val').innerText = pn1;
                    document.getElementById('pn2-val').innerText = pn2;
                    document.getElementById('email-val').innerText = email;
                    document.getElementById('fb-val').innerText = fb;
                    document.getElementById('insta-val').innerText = insta;
                    document.getElementById('tw-val').innerText = tw;
                    bootstrap.Modal.getInstance(document.getElementById('contact-settings-modal')).hide();
                } else {
                    showAlert('danger', 'Failed to update contact settings.');
                }
            } catch (err) {
                showAlert('danger', 'Error updating contact settings.');
            }
        });
    </script>
</body>
</html>
